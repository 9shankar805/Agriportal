rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ── Users ─────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read:   if isSignedIn();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();

      // Per-user notifications sub-collection
      match /notifications/{notifId} {
        allow read:   if isOwner(uid);
        allow create: if isSignedIn();
        allow update: if isOwner(uid);
        allow delete: if isOwner(uid);
      }

      // Per-user saved lands sub-collection
      match /savedLands/{landId} {
        allow read, write: if isOwner(uid);
      }

      // Per-user wallet balance doc
      match /wallet/{docId} {
        allow read, write: if isOwner(uid);
      }

      // Per-user wallet transactions sub-collection
      match /walletTransactions/{txnId} {
        allow read, write: if isOwner(uid);
      }
    }

    // ── Land Listings ─────────────────────────────────────────────────────
    match /lands/{landId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn() &&
                    request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() &&
                    (resource.data.ownerId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() &&
                    (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // ── Applications ──────────────────────────────────────────────────────
    match /applications/{appId} {
      allow read: if isSignedIn() && (
        resource.data.applicantId == request.auth.uid ||
        resource.data.ownerId    == request.auth.uid ||
        isAdmin()
      );
      allow create: if isSignedIn() &&
                    request.resource.data.applicantId == request.auth.uid;
      allow update: if isSignedIn() &&
                    (resource.data.ownerId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // ── Admins ────────────────────────────────────────────────────────────
    // Non-admins need read access so isAdmin() can resolve without
    // a recursive permission-denied error for regular users.
    match /admins/{uid} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Support Messages ──────────────────────────────────────────────────
    match /supportMessages/{msgId} {
      allow create: if isSignedIn();
      allow read:   if isAdmin();
      allow update, delete: if isAdmin();
    }
  }
}
