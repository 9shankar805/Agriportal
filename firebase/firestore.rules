rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ── Users ─────────────────────────────────────────────────────────────
    // Any signed-in user can read any user profile (needed for chat, listings)
    // Only the owner or an admin can write their own profile
    match /users/{uid} {
      allow read:  if isSignedIn();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();

      // Per-user notifications sub-collection
      match /notifications/{notifId} {
        allow read:   if isOwner(uid);
        allow create: if isSignedIn(); // service writes notifications on behalf of others
        allow update: if isOwner(uid);
        allow delete: if isOwner(uid);
      }

      // Per-user saved lands sub-collection
      match /savedLands/{landId} {
        allow read, write: if isOwner(uid);
      }
    }

    // ── Land Listings ─────────────────────────────────────────────────────
    // Anyone signed in can read active/approved/pending lands
    // Only the land owner can create/update/delete their own listing
    match /lands/{landId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
                    request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() &&
                    (resource.data.ownerId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() &&
                    (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // ── Applications ──────────────────────────────────────────────────────
    // Applicant can read/create their own applications
    // Land owner can read applications for their lands
    // Admin can read/update all
    match /applications/{appId} {
      allow read: if isSignedIn() && (
        resource.data.applicantId == request.auth.uid ||
        resource.data.ownerId    == request.auth.uid ||
        isAdmin()
      );
      allow create: if isSignedIn() &&
                    request.resource.data.applicantId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ── Admins ────────────────────────────────────────────────────────────
    // Only admins can read/write the admins collection
    match /admins/{uid} {
      allow read:  if isAdmin();
      allow write: if isAdmin();
    }

    // ── Support Messages ──────────────────────────────────────────────────
    // Any signed-in user can submit; only admins can read all
    match /supportMessages/{msgId} {
      allow create: if isSignedIn();
      allow read:   if isAdmin();
      allow update, delete: if isAdmin();
    }
  }
}
